{
  "name": "hodl-vault-app",
  "version": "4.0.1",
  "description": "HodlVault Monorepo - Secure BCH Vault Application",
  "private": true,
  "scripts": {
    "dev:frontend": "pnpm --filter @hodlvault/frontend dev",
    "dev:backend": "pnpm --filter @hodlvault/backend dev",
    "build": "pnpm --filter @hodlvault/frontend build && pnpm --filter @hodlvault/backend build",
    "build:frontend": "pnpm --filter @hodlvault/frontend build",
    "build:backend": "pnpm --filter @hodlvault/backend build",
    "test": "pnpm --filter @hodlvault/backend test",
    "lint": "pnpm --filter @hodlvault/frontend lint",
    "format": "prettier --write \"**/*.{js,vue,ts,scss,html,md,json}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  }
}
